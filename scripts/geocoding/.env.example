# ジオコーディングAPI設定
# 使用するAPIタイプを選択 (gsi, google, nominatim)
# gsi: 国土地理院API（無料、日本特化、推奨）
# google: Google Maps API（高精度、有料）
# nominatim: OpenStreetMap（無料、世界対応）
GEOCODING_API_TYPE=gsi

# Google Maps APIを使用する場合のみ設定
# https://developers.google.com/maps/documentation/geocoding/get-api-key
GOOGLE_MAPS_API_KEY=

# API呼び出し間隔（ミリ秒）
# レート制限を避けるため、必要に応じて調整
API_DELAY_MS=1000