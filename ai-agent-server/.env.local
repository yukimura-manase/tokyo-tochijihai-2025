# Local development environment variables

# Application settings
APP_NAME=AI Agent Server
APP_VERSION=1.0.0
DEBUG=true

# Server settings
HOST=0.0.0.0
PORT=8000

# Ollama settings (for local development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi4-mini

# OpenAI settings (optional)
USE_OPENAI=false
# OPENAI_API_KEY=your-api-key-here
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Embedding settings
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DEVICE=cpu

# Data paths (adjust these to your local paths)
DATASET_BASE_DIR=../dataset

# Evacuation RAG settings
EVAC_CSV_PATH=../dataset/001_避難所位置情報/130001_evacuation_area.csv
EVAC_PERSIST_DIR=./chroma_evac

# PDF RAG settings
PDF_PATH=../dataset/003_防災計画/2023_1.pdf
PDF_PERSIST_DIR=./chroma_pdf
PDF_CHUNK_SIZE=1000
PDF_CHUNK_OVERLAP=200

# WiFi RAG settings
WIFI_EXCEL_PATH=../dataset/002_wifiスポット/130001_public_wireless_lan_20240901.xlsx
WIFI_PERSIST_DIR=./chroma_wifi

# Vector store settings
CHROMA_BASE_DIR=./chroma_db

# RAG settings
DEFAULT_K_SEMANTIC=30
DEFAULT_K_RESULTS=8
# DEFAULT_RADIUS_KM=

# LLM settings
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=1000